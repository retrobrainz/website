<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
      RetroBrainz - The Open Database for Retro Video Game Enthusiasts
    </title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" sizes="512x512" />
    <script>
      (function () {
        var storedTheme = localStorage.getItem('retrobrainz-theme')
        if (storedTheme === 'dark' || storedTheme === 'light') {
          document.documentElement.setAttribute('data-theme', storedTheme)
        }
      })()
    </script>
    <style>
      html[data-theme='dark'],
      html[data-theme='dark'] body {
        background: #141414;
        color: rgba(255, 255, 255, 0.85);
      }

      html[data-theme='light'],
      html[data-theme='light'] body {
        background: #f5f5f5;
      }
    </style>
    @viteReactRefresh()
    @vite(['resources/js/app.tsx'])
    @stack('dumper')
  </head>
  <body style="margin:0">
    <div id="app"></div>
  </body>
</html>
